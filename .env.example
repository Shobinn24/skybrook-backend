# Skybrook environment variables

# --- Database ---
DATABASE_URL=postgres://shobinnclark@localhost:5432/skybrook_dev

# --- Auth (Google Workspace SSO) ---
# OAuth client from Google Cloud Console (OAuth consent screen: "Internal",
# Application type: "Web application"). Required redirect URI in the console:
#   $APP_URL/api/auth/google/callback
# For local dev: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The Workspace domain users must belong to (the `hd` claim on the ID token).
GOOGLE_WORKSPACE_DOMAIN=everdries.com
# Optional hard allowlist. Comma-separated emails. If empty, any verified
# Workspace user on GOOGLE_WORKSPACE_DOMAIN gets in.
ALLOWED_EMAILS=
# Public origin of the app — used to build the OAuth redirect URI. Must exactly
# match what is registered in Google Cloud Console.
#   Prod:  https://skybrook-backend-production.up.railway.app
#   Local: http://localhost:3000
APP_URL=http://localhost:3000
# Signs the session cookie and the OAuth state token. Generate: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME
# --- Dev-only auth bypass ---
# Set SKYBROOK_DEV_BYPASS=1 in local .env to enable GET /api/auth/dev-login,
# which issues a session cookie without going through Google. The handler
# returns 404 in production regardless of this flag. Only used during local
# dev when the developer is not on the OAuth client's test-users list.
SKYBROOK_DEV_BYPASS=
SKYBROOK_DEV_EMAIL=dev@localhost

# --- Cron ---
# Generate with: openssl rand -base64 32
CRON_SECRET=CHANGE_ME

# --- Google Sheets (inventory source) ---
# Provide ONE of these two — file path is preferred for local dev, JSON content for cloud deploys.
#   Local dev:   GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#   Cloud (Railway): GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'  (single line, single-quoted)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
INVENTORY_SHEET_ID=10zgTSE4iJtRHCgryGT3Noxs8RoUShxkKu-hB-KRv6lc
INCOMING_PO_SHEET_ID=1NaDU--HYArFYWOeACV0LQm4dc67zNQEqT27t_-k_7SI

# --- Shopify (both stores via single Dev Dashboard app) ---
# Auth model (Shopify retired legacy shpat_* tokens on 2026-01-01):
#   App ID + secret → per-store OAuth client_credentials → 24h token.
#   The 24h token is fetched + cached in-memory at runtime, no env var.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_US_STORE=incontinencepanties.myshopify.com
SHOPIFY_INTL_STORE=everdries-international.myshopify.com
# App scopes: read_inventory, read_orders, read_products, read_reports
