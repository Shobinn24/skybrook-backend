# Skybrook environment variables

# --- Database ---
DATABASE_URL=postgres://shobinnclark@localhost:5432/skybrook_dev

# --- Auth (Google Workspace SSO) ---
# OAuth client from Google Cloud Console (OAuth consent screen: "Internal",
# Application type: "Web application"). Required redirect URI in the console:
#   $APP_URL/api/auth/google/callback
# For local dev: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The Workspace domain users must belong to (the `hd` claim on the ID token).
GOOGLE_WORKSPACE_DOMAIN=everdries.com
# Optional hard allowlist. Comma-separated emails. If empty, any verified
# Workspace user on GOOGLE_WORKSPACE_DOMAIN gets in.
ALLOWED_EMAILS=
# Marketing-role allowlist (Scott 2026-05-15). Comma-separated emails of
# users whose nav is restricted to /launches, /fb-ads, /bonus-tracker, and
# /performance — every other page silently redirects to /performance.
# Empty/unset = nobody is marketing = everyone gets ops (full access).
# Note: per-tRPC-procedure gating is a Phase 2 follow-up; in Phase 1 a
# marketing user could still call inventory.* procedures via curl. They
# can't discover them through the UI though.
SKYBROOK_MARKETING_EMAILS=
# Comma-separated allowlist of emails permitted to view /cashflow (sensitive
# company cash position). Fail-closed: empty/unset = nobody can access it.
# Set the real values in Railway before deploy; do not commit real emails.
SKYBROOK_CASHFLOW_EMAILS=
# Public origin of the app — used to build the OAuth redirect URI. Must exactly
# match what is registered in Google Cloud Console.
#   Prod:  https://skybrook-backend-production.up.railway.app
#   Local: http://localhost:3000
APP_URL=http://localhost:3000
# Signs the session cookie and the OAuth state token. Generate: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME
# --- Dev-only auth bypass ---
# Set SKYBROOK_DEV_BYPASS=1 in local .env to enable GET /api/auth/dev-login,
# which issues a session cookie without going through Google. The handler
# returns 404 in production regardless of this flag. Only used during local
# dev when the developer is not on the OAuth client's test-users list.
SKYBROOK_DEV_BYPASS=
SKYBROOK_DEV_EMAIL=dev@localhost

# --- Cron ---
# Generate with: openssl rand -base64 32
CRON_SECRET=CHANGE_ME

# --- Google Sheets (inventory source) ---
# Provide ONE of these two — file path is preferred for local dev, JSON content for cloud deploys.
#   Local dev:   GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#   Cloud (Railway): GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'  (single line, single-quoted)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
INVENTORY_SHEET_ID=10zgTSE4iJtRHCgryGT3Noxs8RoUShxkKu-hB-KRv6lc
INCOMING_PO_SHEET_ID=1NaDU--HYArFYWOeACV0LQm4dc67zNQEqT27t_-k_7SI
# Supermetrics FB ad-spend sheet (one tab per product × ad platform).
# Refreshed at 4am LA time daily; the regular 14:00 UTC ingest cron
# re-pulls and truncate-replaces ad_spend_daily.
AD_SPEND_SHEET_ID=1Qw-ypQiwJCag_6CZk0kN67lf8NrxqTUv4mCu7fPf02c
# Scott's velocity sheet — used at sync time to map SKU → internal
# product name (column B "Style ..." → column C SKU under "EV Main"
# tab). Optional; sync no-ops when unset, falling back to the SKU
# pattern parser for new product names.
EVERDRIES_VELOCITY_SHEET_ID=1ra1vvx_43oIWJN1ZonV0Nd_WpNgxCYpARasuWYmybAQ

# Scott's landed-cost sheet — used at sync time to populate
# `skus.unit_cost_usd` from the leftmost (most recent) US column on
# the EVSKUmap tab. Optional; sync no-ops when unset.
EVERDRIES_COST_SHEET_ID=15ycRH-u43kWMGb52PGGpBu_2v6iDH39RJUPUFfkh9YA

# --- Shopify (both stores via single Dev Dashboard app) ---
# Auth model (Shopify retired legacy shpat_* tokens on 2026-01-01):
#   App ID + secret → per-store OAuth client_credentials → 24h token.
#   The 24h token is fetched + cached in-memory at runtime, no env var.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_US_STORE=incontinencepanties.myshopify.com
SHOPIFY_INTL_STORE=everdries-international.myshopify.com
# App scopes: read_inventory, read_orders, read_products, read_reports

# --- Slack monitoring fanout ---
# One incoming webhook per channel. Create at https://api.slack.com/apps
# → your app → Incoming Webhooks → Add New Webhook to Workspace.
# These ARE secrets (anyone with the URL can post as your app); never
# commit real values. .env is gitignored, .env.example is not.
SLACK_WEBHOOK_ALERTS_URL=
SLACK_WEBHOOK_DIGEST_URL=
SLACK_WEBHOOK_DEBUG_URL=
# Comma-separated Slack member IDs to @mention on P0 alerts (push
# notification trigger; channel posts aren't real DMs). Find via Slack
# profile → ⋯ → "Copy member ID". E.g. "U0B37DUSLUX,U0B37SCOTT".
SLACK_MENTION_USER_IDS=
# Healthchecks.io ping URL for the /api/health endpoint. The cron POSTs
# here on success; HC fires Slack if no ping arrives within the grace
# window. Create at https://healthchecks.io.
HEALTHCHECK_PING_URL=
